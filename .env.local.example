# Convex configures these for you when you run `npx convex dev`.
# You usually don't need to edit them by hand.

NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
CONVEX_DEPLOYMENT=dev:YOUR-DEPLOYMENT-NAME

# Set to wherever the site is served. Used for sign-in redirects.
# Local: http://localhost:3000
# Codespaces: https://<codespace>-3000.app.github.dev
# Production: your domain
SITE_URL=http://localhost:3000

# Support number for the floating "Chat on WhatsApp" button.
# Digits only: country code + number (no "+", spaces or dashes). Falls back to a placeholder if unset.
NEXT_PUBLIC_WHATSAPP_NUMBER=14165550123
